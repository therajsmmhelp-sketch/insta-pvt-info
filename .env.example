# RapidAPI credentials for the "flashapi1" Instagram Info API.
# Get these from your RapidAPI dashboard: https://rapidapi.com/
# These are SERVER-ONLY variables. They are never sent to the browser
# because they are only read inside /app/api/user/route.ts (a server route).

RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=flashapi1.p.rapidapi.com
